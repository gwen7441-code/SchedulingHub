{
  "name": "@first-aid/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "nest start --watch",
    "build": "nest build",
    "start": "node dist/main.js",
    "lint": "eslint src test",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate deploy",
    "prisma:dev": "prisma migrate dev",
    "prisma:seed": "tsx prisma/seed.ts",
    "dynamics:validate": "tsx src/integrations/dynamics/cli.ts validate",
    "dynamics:test-write": "tsx src/integrations/dynamics/cli.ts test-write",
    "dynamics:sync": "tsx src/integrations/dynamics/cli.ts sync all",
    "dynamics:sync:courses": "tsx src/integrations/dynamics/cli.ts sync courses",
    "dynamics:sync:instructors": "tsx src/integrations/dynamics/cli.ts sync instructors",
    "dynamics:sync:assignments": "tsx src/integrations/dynamics/cli.ts sync assignments",
    "dynamics:sync:availability": "tsx src/integrations/dynamics/cli.ts sync availability"
  },
  "dependencies": {
    "@nestjs/bullmq": "^10.2.3",
    "@nestjs/common": "^10.4.15",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.15",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.4.15",
    "@nestjs/swagger": "^8.1.0",
    "@prisma/client": "^6.1.0",
    "@sendgrid/mail": "^8.1.4",
    "@azure/msal-node": "^2.16.2",
    "argon2": "^0.41.1",
    "bullmq": "^5.34.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "compression": "^1.7.5",
    "cookie-parser": "^1.4.7",
    "dotenv": "^16.4.7",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "ioredis": "^5.4.2",
    "jose": "^5.9.6",
    "nanoid": "^5.0.9",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pino": "^9.5.0",
    "pino-http": "^10.4.0",
    "prisma": "^6.1.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "twilio": "^5.4.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.8",
    "@nestjs/testing": "^10.4.15",
    "@types/compression": "^1.7.5",
    "@types/cookie-parser": "^1.4.8",
    "@types/express": "^5.0.0",
    "@types/passport-jwt": "^4.0.1",
    "supertest": "^7.0.0",
    "tsx": "^4.19.2",
    "vitest": "^2.1.8"
  }
}
